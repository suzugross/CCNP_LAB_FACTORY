! ENARSI-REDIST-LOOP-01 初期 RT03 (境界: OSPF/EIGRP・相互再配送は受験者)
! 会社ポリシー: EIGRP の AD は internal 90 / external 95 に固定（変更不可）
interface Loopback0
 ip address {{ params.rt03_lo }} 255.255.255.255
!
interface {{ links[0] }}
 ip address {{ params.seg13 }}.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 ip address {{ params.seg23 }}.2 255.255.255.252
 no shutdown
!
interface {{ links[2] }}
 ip address {{ params.seg34 }}.1 255.255.255.252
 no shutdown
!
router ospf 1
 network {{ params.rt03_lo }} 0.0.0.0 area 0
 network {{ params.seg13 }}.0 0.0.0.3 area 0
!
router eigrp 100
 network {{ params.seg23 }}.0 0.0.0.3
 network {{ params.seg34 }}.0 0.0.0.3
 no auto-summary
 distance eigrp 90 95
!
