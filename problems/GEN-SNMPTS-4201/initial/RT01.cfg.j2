! --- data plane ---
interface Loopback0
 ip address 63.63.63.63 255.255.255.255
interface Ethernet0/0
 description === to ZBX01(poller) ===
 ip address 10.99.0.1 255.255.255.252
 no shutdown
interface Ethernet0/1
 description === to RT02 ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
router ospf 1
 router-id 63.63.63.63
 network 63.63.63.63 0.0.0.0 area 0
 network 10.99.0.0 0.0.0.3 area 0
 network 10.1.12.0 0.0.0.3 area 0
! --- SNMPv3 (NOC 監視標準) ---
snmp-server view MONVIEW iso included
snmp-server group MONGRP v3 priv read MONVIEW
snmp-server location CCNP-LAB
