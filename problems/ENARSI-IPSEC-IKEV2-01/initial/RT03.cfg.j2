! ENARSI-IPSEC-IKEV2-01 初期状態 (RT03 = 支店2/Branch2)
!   links[0] = RT04(WAN transit) 向け underlay (tunnel source)
!   Lo0 = 3.3.3.3 / Lo10 = 支店2 LAN相当 192.168.3.0/24
!   ※ VPN(IKEv2/IPsec/Tunnel1/EIGRP)は未設定。受験者が構築する。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface Loopback10
 description === Branch2 LAN (simulated) ===
 ip address 192.168.3.1 255.255.255.0
!
interface {{ links[0] }}
 description === underlay to RT04 (WAN transit) ===
 ip address 10.0.34.1 255.255.255.252
 no shutdown
!
ip route 0.0.0.0 0.0.0.0 10.0.34.2
!
