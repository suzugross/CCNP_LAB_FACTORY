! ENCOR-IPSLA-02 初期状態 (RT01 = client) ← 受験者が IP SLA/Track/経路を構成する
!   links[0] = RT02 (primary access) 10.0.12.0/30
!   links[1] = RT03 (backup access)  10.0.13.0/30
!   Lo0 = 1.1.1.1（社内アドレス・データの送信元）
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (primary access) ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (backup access) ===
 ip address 10.0.13.1 255.255.255.252
 no shutdown
!
