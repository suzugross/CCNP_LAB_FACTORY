! ENARSI-BGP-AGGREGATE-01 初期状態 (RT03, AS65003) : 下流。BGP 構築済み(変更不要)。
! RT01 から経路を受け取るのみ。
! links[0] = RT01 向け
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (eBGP AS65001) ===
 ip address 10.1.13.2 255.255.255.252
 no shutdown
!
router bgp 65003
 bgp log-neighbor-changes
 neighbor 10.1.13.1 remote-as 65001
!
