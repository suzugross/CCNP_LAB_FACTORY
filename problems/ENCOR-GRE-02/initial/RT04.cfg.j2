! ENCOR-GRE-02 初期状態 (RT04, Branch2) : underlay OSPF 既設。GRE/overlay は受験者が設定。
! links[0] = RT02(transit) 向け
interface Loopback0
 ip address 4.4.4.4 255.255.255.255
!
interface Loopback10
 description === Branch2 Private LAN (simulated) ===
 ip address 10.10.4.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (underlay) ===
 ip address 10.0.24.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 4.4.4.4
 network 4.4.4.4 0.0.0.0 area 0
 network 10.0.24.0 0.0.0.3 area 0
!
