! ENARSI-BGP-COMM-01 初期 (RT01 = AS65001 advertiser)
! BGP up + 10.100.0.0/24 を広告。community のタグ付けと送出は未設定。
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface Loopback100
 description === Service ===
 ip address 10.100.0.1 255.255.255.0
!
interface {{ links[0] }}
 description === to RT02 (eBGP) ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
!
router bgp 65001
 bgp router-id 1.1.1.1
 neighbor 10.1.12.2 remote-as 65002
 network 10.100.0.0 mask 255.255.255.0
!
