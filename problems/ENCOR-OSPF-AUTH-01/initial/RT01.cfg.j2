! ENCOR-OSPF-AUTH-01 初期状態 (RT01)
!   links[0] = RT02 向け
!   area 0 のみ。認証はまだ無し（受験者が追加する）。
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (area 0) ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
!
