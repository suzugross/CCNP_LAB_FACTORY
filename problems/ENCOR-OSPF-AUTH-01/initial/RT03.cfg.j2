! ENCOR-OSPF-AUTH-01 初期状態 (RT03)
!   links[0] = RT02 向け
!   area 0 のみ。認証はまだ無し（受験者が追加する）。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (area 0) ===
 ip address 10.0.23.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 3.3.3.3
 network 3.3.3.3 0.0.0.0 area 0
 network 10.0.23.0 0.0.0.3 area 0
!
