! ENCOR-PBR-02 初期状態 (RT01 = 拠点エッジ) : OSPF 既設。受験者が解くノード。
!   links[0] = RT02(WAN-A) / links[1] = RT03(WAN-B) / links[2] = RT04(拠点LAN)
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (WAN-A) ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (WAN-B) ===
 ip address 10.0.13.1 255.255.255.252
 no shutdown
!
interface {{ links[2] }}
 description === to RT04 (拠点LAN) ===
 ip address 10.0.14.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
 network 10.0.13.0 0.0.0.3 area 0
 network 10.0.14.0 0.0.0.3 area 0
!
