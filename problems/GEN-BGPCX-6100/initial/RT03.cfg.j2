! RT03 (role=cust, AS=65100) 初期構成
ip access-list extended BLOCK-BGP
 deny tcp any any eq bgp
 deny tcp any eq bgp any
 permit ip any any
!
interface Loopback0
 ip address 10.0.45.45 255.255.255.255
!
interface Loopback1
 ip address 172.16.0.1 255.255.255.0
!
interface Loopback2
 ip address 172.16.1.1 255.255.255.0
!
interface Loopback3
 ip address 172.16.2.1 255.255.255.0
!
interface {{ links[0] }}
 ip address 10.118.118.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 ip address 10.177.177.2 255.255.255.252
 ip access-group BLOCK-BGP in
 no shutdown
!
router bgp 65100
 bgp router-id 10.0.45.45
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.118.118.1 remote-as 65001
 neighbor 10.177.177.1 remote-as 65001
 address-family ipv4 unicast
  neighbor 10.118.118.1 activate
  neighbor 10.177.177.1 activate
  network 172.16.0.0 mask 255.255.255.0
  network 172.16.1.0 mask 255.255.255.0
  network 172.16.2.0 mask 255.255.255.0
 exit-address-family
!
! --- SNMPv3 (NOC 監視標準) ---
snmp-server view MONVIEW iso included
snmp-server group MONGRP v3 priv read MONVIEW
snmp-server location CCNP-LAB
snmp-server user MONUSER MONGRP v3 auth sha CCNP-Auth-2026 priv aes 128 CCNP-Priv-2026
!
