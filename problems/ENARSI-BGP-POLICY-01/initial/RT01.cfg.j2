! ENARSI-BGP-POLICY-01 初期 (RT01, AS{{ params.as_cust }} edge-A/主系)
! eBGP セッションのみ確立済み（ポリシー皆無）。iBGP・全ポリシーは受験者が設定する。
! links[0] = RT04(ISP-A) 向け / links[1] = RT03(内部) 向け
interface Loopback0
 ip address {{ params.rt01_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT04 ISP-A (eBGP AS{{ params.as_ispa }}) ===
 ip address {{ params.seg14 }}.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (internal) ===
 ip address {{ params.seg13 }}.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id {{ params.rt01_lo }}
 network {{ params.rt01_lo }} 0.0.0.0 area 0
 network {{ params.seg13 }}.0 0.0.0.3 area 0
!
router bgp {{ params.as_cust }}
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor {{ params.seg14 }}.2 remote-as {{ params.as_ispa }}
 address-family ipv4
  neighbor {{ params.seg14 }}.2 activate
 exit-address-family
!
