! ENARSI-BGP-NHSELF-01 初期状態 (RT02, AS65001) : AS内ルータ。iBGP 構築済み(変更不要)。
! RT01 と iBGP ピア。外部リンク(10.1.13.0/30)への経路は持たない(=next-hop未解決を誘発)。
! links[0] = RT01 向け
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (iBGP AS65001) ===
 ip address 10.1.12.2 255.255.255.252
 no shutdown
!
router bgp 65001
 bgp log-neighbor-changes
 neighbor 10.1.12.1 remote-as 65001
!
