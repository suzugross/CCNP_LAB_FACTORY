! ENARSI-BGP-NHSELF-01 初期状態 (RT01, AS65001) : 境界。BGP 未設定 = 受験者が解く。
! links[0] = RT02(iBGP, 同一AS65001) 向け / links[1] = RT03(eBGP AS65003) 向け
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (iBGP AS65001) ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (eBGP AS65003) ===
 ip address 10.1.13.1 255.255.255.252
 no shutdown
!
