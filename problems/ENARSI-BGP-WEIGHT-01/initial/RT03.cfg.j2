! ENARSI-BGP-WEIGHT-01 初期 (RT03 = provider B, AS65003, 変更不要)
! 同じ 10.100.0.0/24 (Lo100) を anycast で RT01 に広告。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface Loopback100
 description === Service anycast ===
 ip address 10.100.0.1 255.255.255.0
!
interface {{ links[0] }}
 description === to RT01 (eBGP AS65001) ===
 ip address 10.1.13.2 255.255.255.252
 no shutdown
!
router bgp 65003
 bgp router-id 3.3.3.3
 neighbor 10.1.13.1 remote-as 65001
 network 10.100.0.0 mask 255.255.255.0
!

{% if params.bfd | default(false) %}
! BFD（bfd 変種のみ）: ISP 側は BFD 対応済み（受験者は RT01 側を設定する）
interface {{ links[0] }}
 bfd interval {{ params.bfd_interval }} min_rx {{ params.bfd_interval }} multiplier {{ params.bfd_multiplier }}
!
router bgp 65003
 neighbor 10.1.13.1 fall-over bfd
!
{% endif %}
