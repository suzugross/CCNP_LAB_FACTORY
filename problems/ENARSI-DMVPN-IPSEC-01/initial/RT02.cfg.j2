! ENARSI-DMVPN-IPSEC-01 初期状態 (RT02 = Spoke1)
!   links[0] = RT04(WAN transit) 向け underlay (NBMA)
!   Lo0 = 2.2.2.2
!   ※ VPN(Tunnel0 / NHRP / IKEv2/IPsec / EIGRP)は未設定。受験者が構築する。
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === underlay to RT04 (WAN transit) ===
 ip address 10.0.24.1 255.255.255.252
 no shutdown
!
ip route 0.0.0.0 0.0.0.0 10.0.24.2
!
