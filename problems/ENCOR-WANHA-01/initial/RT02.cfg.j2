! ENCOR-WANHA-01 初期 (RT02, Transit-A / primary) : 中継のみ(変更禁止)。
! 2つの接続 /30 を connected で中継するだけ。
! links[0]=RT01(HQ) / links[1]=RT04(Branch)
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (HQ) ===
 ip address 10.0.12.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT04 (Branch) ===
 ip address 10.0.24.1 255.255.255.252
 no shutdown
!
