! ENCOR-INTEGRATED-01 初期 (RT03, 内部) : OSPF area0 構築済み(変更不要)。
! 値は params/<variant>.yml 由来。  links[0]=RT01 / links[1]=RT02
interface Loopback0
 ip address {{ params.rt03_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (OSPF) ===
 ip address {{ params.seg13 }}.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT02 (OSPF) ===
 ip address {{ params.seg23 }}.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id {{ params.rt03_lo }}
 network {{ params.rt03_lo }} 0.0.0.0 area 0
 network {{ params.seg13 }}.0 0.0.0.3 area 0
 network {{ params.seg23 }}.0 0.0.0.3 area 0
!
