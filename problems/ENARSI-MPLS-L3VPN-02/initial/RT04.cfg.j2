! ENARSI-MPLS-L3VPN-02 初期状態 (RT04 = CUST_A CE1 / 変更不可)
!   OSPF 稼働済み: リンク + LAN(Lo0, point-to-point で /24 のまま広告) + 機器管理(Lo9)。
interface Loopback0
 description === CUST_A site1 LAN (172.16.1.0/24) ===
 ip address 172.16.1.1 255.255.255.0
 ip ospf network point-to-point
!
interface Loopback9
 description === CE 機器管理 (VPN へ広告禁止) ===
 ip address 10.99.4.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 PE1 (192.168.1.0/30) ===
 ip address 192.168.1.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 4.4.4.4
 network 192.168.1.0 0.0.0.3 area 0
 network 172.16.1.0 0.0.0.255 area 0
 network 10.99.4.1 0.0.0.0 area 0
!
