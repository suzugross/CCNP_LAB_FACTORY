! ENCOR-ACL-EXTENDED-01 初期状態 (RT02) : OSPF 既設。ACL は未設定 = 受験者が解く部分。
! links[0] = RT01 向け(ここに inbound ACL を適用させる) / links[1] = RT03 向け
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 ===
 ip address 10.0.12.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (server) ===
 ip address 10.0.23.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 2.2.2.2
 network 2.2.2.2 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
 network 10.0.23.0 0.0.0.3 area 0
!
