! ENARSI-BGP-ROUTEMAP-01 初期 (RT01 = AS65001 receiver)
! BGP up。route-map 未設定 → 全プレフィックスが流入する。
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (eBGP) ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
!
router bgp 65001
 bgp router-id 1.1.1.1
 neighbor 10.1.12.2 remote-as 65002
!
