! --- data plane ---
interface Loopback0
 ip address 98.98.98.98 255.255.255.255
interface Ethernet0/0
 description === to RT01 ===
 ip address 10.1.12.2 255.255.255.252
 no shutdown
interface Ethernet0/1
 description === user LAN (PC01) ===
 ip address 192.168.90.1 255.255.255.0
 ip helper-address 10.99.0.2
 no shutdown
router ospf 1
 router-id 98.98.98.98
 network 98.98.98.98 0.0.0.0 area 0
 network 10.1.12.0 0.0.0.3 area 0
 network 192.168.90.0 0.0.0.255 area 0
ip name-server 10.99.0.2
