! ENCOR-OSPF-STUB-01 初期状態 (RT03 = area 1 内部ルータ)
!   links[0] = RT02 向け (area 1)
!   初期は area 1 通常エリア。RT03 は ASBR 由来 external も area 0 inter-area も全部見える状態。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (area 1) ===
 ip address 10.0.23.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 3.3.3.3
 network 3.3.3.3 0.0.0.0 area 1
 network 10.0.23.0 0.0.0.3 area 1
!
