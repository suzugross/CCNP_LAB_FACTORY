! ENCOR-IPSLA-01 初期状態 (RT03 = backup ISP, 変更禁止)
!   links[0] = RT01 (顧客 / backup access) 10.0.13.0/30
!   links[1] = RT02 (peer ISP / inter-ISP)  10.0.23.0/30
!   links[2] = RT04 (Internet core)         10.0.34.0/30
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (customer / backup access) ===
 ip address 10.0.13.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT02 (peer ISP) ===
 ip address 10.0.23.2 255.255.255.252
 no shutdown
!
interface {{ links[2] }}
 description === to RT04 (Internet core) ===
 ip address 10.0.34.1 255.255.255.252
 no shutdown
!
! Internet(8.8.8.8) は RT04 経由
ip route 8.8.8.8 255.255.255.255 10.0.34.2
! 顧客 RT01(Lo0=1.1.1.1) への直結戻り（RT04 からの戻りは常にこの RT03 経由を primary とする）
ip route 1.1.1.1 255.255.255.255 10.0.13.1
!
