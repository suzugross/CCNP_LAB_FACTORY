! ENARSI-BGP-MED-01 初期 (RT02 = AS65002 receiver, 変更不要)
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (primary link) ===
 ip address 10.1.12.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT01 (backup link) ===
 ip address 10.1.122.2 255.255.255.252
 no shutdown
!
router bgp 65002
 bgp router-id 2.2.2.2
 neighbor 10.1.12.1 remote-as 65001
 neighbor 10.1.122.1 remote-as 65001
!
