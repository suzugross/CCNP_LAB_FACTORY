! DMVPN-POC-01 初期状態 (RT03 = Spoke2)
!   links[0] = RT04(WAN transit) 向け underlay (NBMA)
!   Lo0 = 3.3.3.3 (EIGRP で広告する内部プレフィックス)
!   ※ オーバーレイ(Tunnel0 / NHRP / EIGRP)は未設定。受験者が構築する。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === underlay to RT04 (WAN transit) ===
 ip address 10.0.34.1 255.255.255.252
 no shutdown
!
! underlay: ハブ/対向スポークの NBMA へは RT04 経由(デフォルトルート)
ip route 0.0.0.0 0.0.0.0 10.0.34.2
!
