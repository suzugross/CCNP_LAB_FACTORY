---
problem: ENARSI-BGP-PREFIX-01
{% set bfd = params.bfd | default(false) %}
total_points: 100

defaults:
  genie_os: iosxe

checks:
  - name: "RT01: eBGP ネイバー RT02(10.1.12.2) が Established"
    node: RT01
    command: "show ip bgp neighbors 10.1.12.2"
    parser: "show ip bgp neighbors"
    find: ["vrf", "default", "neighbor", "10.1.12.2"]
    match:
      session_state: { startswith: "Establ" }
    points: {{ 13 if bfd else 15 }}

  - name: "RT01: prefix-list が ge 表記で 10.10.0.0/16 を permit している"
    node: RT01
    command: "show running-config | include ip prefix-list"
    raw:
      - regex: "ip prefix-list +\\S+ +.*permit +10\\.10\\.0\\.0/16 +ge +24"
    points: {{ 18 if bfd else 20 }}

  - name: "RT01: prefix-list が RT02 ピアに inbound 適用されている"
    node: RT01
    command: "show running-config | section router bgp"
    raw:
      - regex: "neighbor +10\\.1\\.12\\.2 +prefix-list +\\S+ +in"
    points: {{ 13 if bfd else 15 }}

  - name: "RT01: 10.10.0.0/24 と 10.10.1.0/24 が BGP テーブルに残っている (許可)"
    node: RT01
    command: "show ip bgp"
    raw:
      - regex: "10\\.10\\.0\\.0"
      - regex: "10\\.10\\.1\\.0"
    points: {{ 27 if bfd else 30 }}

  - name: "RT01: 192.168.0.0/24 が BGP テーブルから消えている (拒否)"
    node: RT01
    command: "show ip bgp"
    raw:
      - not_contains: "192.168.0.0"
    points: {{ 19 if bfd else 20 }}
{% if bfd %}

  - name: "RT01: BFD セッション (10.1.12.2) Up・BGP連動"
    node: RT01
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "10.1.12.2"]
    match:
      state: "Up"
      registered_protocols.*: "BGP"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 10
{% endif %}
