! ENARSI-MPLS-L3VPN-01 初期状態 (RT03 = PE2 / 変更対象)
!   links[0] = RT02(P) コアリンク / links[1] = RT05(CUST_A CE2) / links[2] = RT07(CUST_B CE2)
!   CE 向け IF は IP 設定済みだが VRF 未収容 (受験者が VRF 収容する)。
!   ★IOL day0 癖: IP の無い IF 節は no shutdown が効かない (RT01 側コメント参照)。
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 P (10.1.23.0/30) ===
 ip address 10.1.23.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT05 CUST_A-CE2 (192.168.2.0/30) ===
 ip address 192.168.2.2 255.255.255.252
 no shutdown
!
interface {{ links[2] }}
 description === to RT07 CUST_B-CE2 (192.168.12.0/30) ===
 ip address 192.168.12.2 255.255.255.252
 no shutdown
!
