! ENCOR-GRE-01 初期状態 (RT03 = Branch)
!   links[0] = RT02 向け (underlay)
!   Lo0 = 3.3.3.3 (OSPF RID / tunnel src 候補)
!   Lo10 = 10.10.3.1/32 (Branch プライベート、underlay には広告しない)
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface Loopback10
 description === Branch Private LAN (simulated) ===
 ip address 10.10.3.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (underlay) ===
 ip address 10.0.23.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 3.3.3.3
 network 3.3.3.3 0.0.0.0 area 0
 network 10.0.23.0 0.0.0.3 area 0
!
