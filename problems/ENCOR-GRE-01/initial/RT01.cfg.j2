! ENCOR-GRE-01 初期状態 (RT01 = HQ)
!   links[0] = RT02 向け (underlay)
!   Lo0 = 1.1.1.1 (OSPF RID / tunnel src 候補)
!   Lo10 = 10.10.1.1/32 (HQ プライベート、underlay には広告しない)
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface Loopback10
 description === HQ Private LAN (simulated) ===
 ip address 10.10.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (underlay) ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
!
