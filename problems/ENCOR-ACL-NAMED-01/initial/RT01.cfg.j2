! ENCOR-ACL-NAMED-01 初期状態 (RT01) : OSPF 既設(変更不要)。
! links[0] = RT02 向け
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
!
