! GEN-LOOPPOC-1 (RT01) — BGP側スピーカ(コア/RR代役)。172.20.0.0/24 の出所
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface Loopback20
 description === West LAN stand-in ===
 ip address 172.20.0.1 255.255.255.0
!
interface {{ links[0] }}
 description === to RT02 ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 ===
 ip address 10.0.13.1 255.255.255.252
 no shutdown
!
router bgp 65001
 bgp router-id 1.1.1.1
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.0.12.2 remote-as 65001
 neighbor 10.0.13.2 remote-as 65001
 address-family ipv4
  neighbor 10.0.12.2 activate
  neighbor 10.0.13.2 activate
  network 172.20.0.0 mask 255.255.255.0
 exit-address-family
!
