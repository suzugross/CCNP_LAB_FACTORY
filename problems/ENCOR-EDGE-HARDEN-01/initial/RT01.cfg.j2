! ENCOR-EDGE-HARDEN-01 初期 (RT01, ハードニング対象) : OSPF 既設。受験者が多層防御を追加。
! links[0]=RT02(隣接/OSPF)
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (隣接セグメント) ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
!
