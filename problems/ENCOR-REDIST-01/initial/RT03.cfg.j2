! ENCOR-REDIST-01 初期状態 (RT03) : EIGRP ドメインのエッジ。EIGRP は構築済み(受験者は触らない)。
! 値は params/<variant>.yml 由来。  links[0] = RT02 向け (EIGRP)
interface Loopback0
 ip address {{ params.rt03_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (EIGRP) ===
 ip address {{ params.seg23 }}.2 255.255.255.252
 no shutdown
!
router eigrp {{ params.eigrp_as }}
 no auto-summary
 network {{ params.seg23 }}.0 0.0.0.3
 network {{ params.rt03_lo }} 0.0.0.0
!

{% if params.bfd | default(false) %}
! BFD（bfd 変種のみ）: RT03 側は BFD 対応済み（受験者は RT02 側を設定する）
interface {{ links[0] }}
 bfd interval {{ params.bfd_interval }} min_rx {{ params.bfd_interval }} multiplier {{ params.bfd_multiplier }}
!
router eigrp {{ params.eigrp_as }}
 bfd all-interfaces
!
{% endif %}
