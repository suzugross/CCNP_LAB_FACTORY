! ENCOR-REDIST-01 初期状態 (RT01) : OSPF ドメインのエッジ。OSPF は構築済み(受験者は触らない)。
! 値は params/<variant>.yml 由来。  links[0] = RT02 向け (OSPF)
interface Loopback0
 ip address {{ params.rt01_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (OSPF) ===
 ip address {{ params.seg12 }}.1 255.255.255.252
 no shutdown
!
router ospf {{ params.ospf_pid }}
 network {{ params.seg12 }}.0 0.0.0.3 area {{ params.area }}
 network {{ params.rt01_lo }} 0.0.0.0 area {{ params.area }}
!

{% if params.bfd | default(false) %}
! BFD（bfd 変種のみ）: RT01 側は BFD 対応済み（受験者は RT02 側を設定する）
interface {{ links[0] }}
 bfd interval {{ params.bfd_interval }} min_rx {{ params.bfd_interval }} multiplier {{ params.bfd_multiplier }}
 ip ospf bfd
!
{% endif %}
