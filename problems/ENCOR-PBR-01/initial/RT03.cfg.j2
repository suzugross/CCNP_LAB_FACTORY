! ENCOR-PBR-01 初期状態 (RT03 = DC) : OSPF 既設・変更禁止。到達対象 3.3.3.3。
!   links[0] = RT01 向け / links[1] = RT02 向け
interface Loopback0
 description === データセンター ===
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 ===
 ip address 10.0.13.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT02 ===
 ip address 10.0.23.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 3.3.3.3
 network 3.3.3.3 0.0.0.0 area 0
 network 10.0.13.0 0.0.0.3 area 0
 network 10.0.23.0 0.0.0.3 area 0
!
