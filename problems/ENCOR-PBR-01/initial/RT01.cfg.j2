! ENCOR-PBR-01 初期状態 (RT01 = 支社ルータ) : OSPF 既設。受験者が解くノード。
!   Lo0 = ルータID / Lo1 = 営業部セグメント / Lo2 = 開発部セグメント
!   links[0] = RT02 向け / links[1] = RT03 向け
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface Loopback1
 description === 営業部セグメント ===
 ip address 10.1.1.1 255.255.255.255
!
interface Loopback2
 description === 開発部セグメント ===
 ip address 10.2.2.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 ===
 ip address 10.0.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 ===
 ip address 10.0.13.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.1.1.1 0.0.0.0 area 0
 network 10.2.2.1 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
 network 10.0.13.0 0.0.0.3 area 0
!
