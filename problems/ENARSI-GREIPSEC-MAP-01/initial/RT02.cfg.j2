! ENARSI-GREIPSEC-MAP-01 初期状態 (RT02 = 支店1/Branch1)
!   links[0] = RT04(WAN transit) 向け underlay (tunnel source / crypto map 適用先)
!   Lo0 = 2.2.2.2 / Lo10 = 支店1 LAN相当 192.168.2.0/24
!   ※ VPN(ISAKMP/IPsec/crypto map/Tunnel1/OSPF)は未設定。受験者が構築する。
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface Loopback10
 description === Branch1 LAN (simulated) ===
 ip address 192.168.2.1 255.255.255.0
!
interface {{ links[0] }}
 description === underlay to RT04 (WAN transit) ===
 ip address 10.0.24.1 255.255.255.252
 no shutdown
!
ip route 0.0.0.0 0.0.0.0 10.0.24.2
!
