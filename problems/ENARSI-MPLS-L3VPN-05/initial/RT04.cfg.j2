! ENARSI-MPLS-L3VPN-05 初期状態 (RT04 = P1 / BGPフリー / 変更禁止)
!   links[0]=RT01(PE1) / links[1]=RT05(P2) / links[2]=RT06(P3)
interface Loopback0
 ip address 4.4.4.4 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 PE1 (10.1.14.0/30) ===
 ip address 10.1.14.2 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[1] }}
 description === to RT05 P2 (10.1.45.0/30) ===
 ip address 10.1.45.1 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[2] }}
 description === to RT06 P3 (10.1.46.0/30) ===
 ip address 10.1.46.1 255.255.255.252
 mpls ip
 no shutdown
!
mpls ldp router-id Loopback0 force
!
router ospf 1
 router-id 4.4.4.4
 network 4.4.4.4 0.0.0.0 area 0
 network 10.1.14.0 0.0.0.3 area 0
 network 10.1.45.0 0.0.0.3 area 0
 network 10.1.46.0 0.0.0.3 area 0
