! ENARSI-MPLS-L3VPN-05 初期状態 (RT05 = P2 / BGPフリー / 変更禁止)
!   links[0]=RT02(PE2) / links[1]=RT04(P1) / links[2]=RT06(P3)
interface Loopback0
 ip address 5.5.5.5 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 PE2 (10.1.25.0/30) ===
 ip address 10.1.25.2 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[1] }}
 description === to RT04 P1 (10.1.45.0/30) ===
 ip address 10.1.45.2 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[2] }}
 description === to RT06 P3 (10.1.56.0/30) ===
 ip address 10.1.56.1 255.255.255.252
 mpls ip
 no shutdown
!
mpls ldp router-id Loopback0 force
!
router ospf 1
 router-id 5.5.5.5
 network 5.5.5.5 0.0.0.0 area 0
 network 10.1.25.0 0.0.0.3 area 0
 network 10.1.45.0 0.0.0.3 area 0
 network 10.1.56.0 0.0.0.3 area 0
