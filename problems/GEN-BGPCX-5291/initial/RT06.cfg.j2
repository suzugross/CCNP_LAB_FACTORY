! RT06 (role=mhop, AS=65200) 初期構成
interface Loopback0
 ip address 10.0.87.87 255.255.255.255
!
interface Loopback1
 ip address 198.51.100.1 255.255.255.0
!
interface {{ links[0] }}
 ip address 10.101.101.2 255.255.255.252
 no shutdown
!
ip route 10.0.30.30 255.255.255.255 10.101.101.1
!
router bgp 65200
 bgp router-id 10.0.87.87
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.0.30.30 remote-as 65001
 neighbor 10.0.30.30 update-source Loopback0
 address-family ipv4 unicast
  neighbor 10.0.30.30 activate
  network 198.51.100.0 mask 255.255.255.0
 exit-address-family
!
