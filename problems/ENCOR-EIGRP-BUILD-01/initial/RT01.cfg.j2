! ENCOR-EIGRP-BUILD-01 初期状態 (RT01) — コア。EIGRP は未構成。
!   links[0] = RT02 向け / links[1] = RT03 向け(広域・高遅延)
interface Loopback0
 ip address 10.0.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (10.1.12.0/30) ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (10.1.13.0/30) WAN/high-latency ===
 ip address 10.1.13.1 255.255.255.252
 delay 5000
 no shutdown
!
