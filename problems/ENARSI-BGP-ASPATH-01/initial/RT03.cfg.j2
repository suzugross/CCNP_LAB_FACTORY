! ENARSI-BGP-ASPATH-01 初期 (RT03 = AS65003 originator, 変更不要)
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface Loopback103
 description === Service AS65003 ===
 ip address 10.3.0.1 255.255.255.0
!
interface {{ links[0] }}
 description === to RT02 (eBGP) ===
 ip address 10.1.23.2 255.255.255.252
 no shutdown
!
router bgp 65003
 bgp router-id 3.3.3.3
 neighbor 10.1.23.1 remote-as 65002
 network 10.3.0.0 mask 255.255.255.0
!
