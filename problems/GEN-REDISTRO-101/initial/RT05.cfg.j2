! RT05 初期構成 (相互再配送 RIP⇄OSPF TS・故障注入済)
interface Loopback0
 ip address 60.60.60.60 255.255.255.255
!
interface {{ links[0] }}
 ip address 172.16.73.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 ip address 172.16.124.2 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 60.60.60.60
 network 60.60.60.60 0.0.0.0 area 0
 network 172.16.73.0 0.0.0.3 area 0
 network 172.16.124.0 0.0.0.3 area 0
!
