! ENCOR-OSPF-NSSA-01 初期状態 (RT02 = ABR, area 0 と area 1 の境界)
!   links[0] = RT01 向け (area 0) / links[1] = RT03 向け (area 1)
!   初期は area 1 を通常エリアとして配備（受験者が area タイプを変更する）。
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (area 0) ===
 ip address 10.0.12.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (area 1) ===
 ip address 10.0.23.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 2.2.2.2
 network 2.2.2.2 0.0.0.0 area 0
 network 10.0.12.0 0.0.0.3 area 0
 network 10.0.23.0 0.0.0.3 area 1
!
