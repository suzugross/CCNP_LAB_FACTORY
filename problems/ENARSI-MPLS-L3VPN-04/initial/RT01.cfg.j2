! ENARSI-MPLS-L3VPN-04 初期状態 (RT01 = PE1 / 変更対象)
!   01 の完成形からスタティック PE-CE と af ipv4 vrf を除いた状態 (02 と同一)。
!   links[0]=RT02(P) / links[1]=RT04(CUST_A CE1) / links[2]=RT06(CUST_B CE1)
vrf definition CUST_A
 rd 65000:100
 address-family ipv4
  route-target export 65000:100
  route-target import 65000:100
 exit-address-family
!
vrf definition CUST_B
 rd 65000:200
 address-family ipv4
  route-target export 65000:200
  route-target import 65000:200
 exit-address-family
!
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 P (10.1.12.0/30) ===
 ip address 10.1.12.1 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[1] }}
 description === to RT04 CUST_A-CE1 (192.168.1.0/30) ===
 vrf forwarding CUST_A
 ip address 192.168.1.2 255.255.255.252
 no shutdown
!
interface {{ links[2] }}
 description === to RT06 CUST_B-CE1 (192.168.11.0/30) ===
 vrf forwarding CUST_B
 ip address 192.168.11.2 255.255.255.252
 no shutdown
!
mpls ldp router-id Loopback0 force
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 10.1.12.0 0.0.0.3 area 0
!
router bgp 65000
 bgp router-id 1.1.1.1
 no bgp default ipv4-unicast
 neighbor 3.3.3.3 remote-as 65000
 neighbor 3.3.3.3 update-source Loopback0
 address-family vpnv4
  neighbor 3.3.3.3 activate
 exit-address-family
!
