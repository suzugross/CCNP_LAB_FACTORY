! ENARSI-MPLS-L3VPN-04 初期状態 (RT02 = P / 構成済み・変更不要)
!   links[0] = RT01(PE1) / links[1] = RT03(PE2)。OSPF + LDP のみ (BGP フリー)。
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 PE1 (10.1.12.0/30) ===
 ip address 10.1.12.2 255.255.255.252
 mpls ip
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 PE2 (10.1.23.0/30) ===
 ip address 10.1.23.1 255.255.255.252
 mpls ip
 no shutdown
!
mpls ldp router-id Loopback0 force
!
router ospf 1
 router-id 2.2.2.2
 network 2.2.2.2 0.0.0.0 area 0
 network 10.1.12.0 0.0.0.3 area 0
 network 10.1.23.0 0.0.0.3 area 0
!
