! ENCOR-COPP-03 初期状態 (RT01 = 保護対象ルータ)
!   links[0] = RT02 (OSPF隣接 / 試験トラフィック源)  {{ params.seg12 }}.0/30
!   OSPF area {{ params.area }} は事前設定済み（隣接 FULL が初期状態）。
!   CoPP は未設定 = 受験者がここを構成する。
interface Loopback0
 ip address {{ params.rt01_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 (OSPF neighbor / traffic source) ===
 ip address {{ params.seg12 }}.1 255.255.255.252
 no shutdown
!
router ospf {{ params.ospf_pid }}
 network {{ params.rt01_lo }} 0.0.0.0 area {{ params.area }}
 network {{ params.seg12 }}.0 0.0.0.3 area {{ params.area }}
!
