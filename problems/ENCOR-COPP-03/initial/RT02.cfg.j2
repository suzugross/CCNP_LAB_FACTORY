! ENCOR-COPP-03 初期状態 (RT02 = OSPF隣接 / 試験トラフィック源, 変更禁止)
!   links[0] = RT01  {{ params.seg12 }}.0/30
!   OSPF area {{ params.area }} 事前設定済み。RT01 の CoPP 検証用トラフィック源。
interface Loopback0
 ip address {{ params.rt02_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (CoPP target router) ===
 ip address {{ params.seg12 }}.2 255.255.255.252
 no shutdown
!
router ospf {{ params.ospf_pid }}
 network {{ params.rt02_lo }} 0.0.0.0 area {{ params.area }}
 network {{ params.seg12 }}.0 0.0.0.3 area {{ params.area }}
!
