! ENCOR-FNF-01 初期状態 (RT02 = FNF 監視ルータ) ← 受験者が FNF を構成する。
! 値は params/<variant>.yml 由来。
!   links[0] = RT01 向け (Et0/0・監視対象の ingress IF) / links[1] = RT03 向け (Et0/1)
!   OSPF area0 既設。Lo0 = {{ params.rt02_lo }}。
!   ※ Flexible NetFlow(flow record / exporter / monitor と IF適用)は未設定。
interface Loopback0
 ip address {{ params.rt02_lo }} 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (monitor ingress here) ===
 ip address {{ params.seg12 }}.2 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 ===
 ip address {{ params.seg23 }}.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id {{ params.rt02_lo }}
 network {{ params.rt02_lo }} 0.0.0.0 area 0
 network {{ params.seg12 }}.0 0.0.0.3 area 0
 network {{ params.seg23 }}.0 0.0.0.3 area 0
!
