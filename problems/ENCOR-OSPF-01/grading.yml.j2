---
# 採点基準（パラメータ化テンプレート）。値は params/<variant>.yml 由来。
# ルートは command="show ip route ospf"(実機) / parser="show ip route"。状態は startswith FULL。
# bfd 変種: 既存チェックを 16 点に圧縮し、BFD セッション 4 チェック(各5点)を追加（合計100点維持）。
{% set bfd = params.bfd | default(false) %}
{% set base_pts = 16 if bfd else 20 %}
problem: ENCOR-OSPF-01
total_points: 100

defaults:
  genie_os: iosxe

checks:
  - name: "RT01: OSPF ネイバー RT02({{ params.seg12 }}.2) が FULL"
    node: RT01
    command: "show ip ospf neighbor"
    parser: "show ip ospf neighbor"
    find: "interfaces.*.neighbors.*"
    match:
      address: "{{ params.seg12 }}.2"
      state: { startswith: "FULL" }
    points: {{ base_pts }}

  - name: "RT01: OSPF ネイバー RT03({{ params.seg13 }}.2) が FULL"
    node: RT01
    command: "show ip ospf neighbor"
    parser: "show ip ospf neighbor"
    find: "interfaces.*.neighbors.*"
    match:
      address: "{{ params.seg13 }}.2"
      state: { startswith: "FULL" }
    points: {{ base_pts }}

  - name: "RT01: {{ params.rt02_lo }}/32 を OSPF 経路で学習 (via RT02 {{ params.seg12 }}.2)"
    node: RT01
    command: "show ip route ospf"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt02_lo }}/32"
      source_protocol: "ospf"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg12 }}.2"
    points: {{ base_pts }}

  - name: "RT01: {{ params.rt03_lo }}/32 を OSPF 経路で学習 (via RT03 {{ params.seg13 }}.2)"
    node: RT01
    command: "show ip route ospf"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt03_lo }}/32"
      source_protocol: "ospf"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg13 }}.2"
    points: {{ base_pts }}

  - name: "RT02: {{ params.rt01_lo }}/32 を OSPF 経路で学習（双方向性確認, via {{ params.seg12 }}.1）"
    node: RT02
    command: "show ip route ospf"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt01_lo }}/32"
      source_protocol: "ospf"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg12 }}.1"
    points: {{ base_pts }}
{% if bfd %}

  - name: "RT01: BFD セッション ({{ params.seg12 }}.2) Up・OSPF連動"
    node: RT01
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg12 }}.2"]
    match:
      state: "Up"
      registered_protocols.*: "OSPF"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT01: BFD セッション ({{ params.seg13 }}.2) Up・OSPF連動"
    node: RT01
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg13 }}.2"]
    match:
      state: "Up"
      registered_protocols.*: "OSPF"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT02: BFD セッション ({{ params.seg12 }}.1) Up・OSPF連動"
    node: RT02
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg12 }}.1"]
    match:
      state: "Up"
      registered_protocols.*: "OSPF"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT03: BFD セッション ({{ params.seg13 }}.1) Up・OSPF連動"
    node: RT03
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg13 }}.1"]
    match:
      state: "Up"
      registered_protocols.*: "OSPF"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5
{% endif %}
