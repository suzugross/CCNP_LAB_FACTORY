---
# 採点基準（パラメータ化テンプレート）。値は params/<variant>.yml 由来。
# grade.yml が params で描画 → _generated/<problem>/grading.rendered.yml を採点に使用。
# 近隣IPは dict キー(ドット入り)のため find をリスト形式で書く。
problem: ENCOR-EIGRP-01
{% set bfd = params.bfd | default(false) %}
total_points: 100

defaults:
  genie_os: iosxe

checks:
  - name: "RT01: EIGRP 近隣 RT02({{ params.seg12 }}.2) が確立"
    node: RT01
    command: "show ip eigrp neighbors"
    parser: "show ip eigrp neighbors"
    find: ["eigrp_instance", "*", "vrf", "*", "address_family", "*", "eigrp_interface", "*", "eigrp_nbr", "{{ params.seg12 }}.2"]
    match: {}
    points: {{ 12 if bfd else 15 }}

  - name: "RT01: EIGRP 近隣 RT03({{ params.seg13 }}.2) が確立"
    node: RT01
    command: "show ip eigrp neighbors"
    parser: "show ip eigrp neighbors"
    find: ["eigrp_instance", "*", "vrf", "*", "address_family", "*", "eigrp_interface", "*", "eigrp_nbr", "{{ params.seg13 }}.2"]
    match: {}
    points: {{ 12 if bfd else 15 }}

  - name: "RT01: {{ params.rt02_lo }}/32 を EIGRP(D) で学習 (via RT02 {{ params.seg12 }}.2)"
    node: RT01
    command: "show ip route eigrp"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt02_lo }}/32"
      source_protocol: "eigrp"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg12 }}.2"
    points: {{ 20 if bfd else 25 }}

  - name: "RT01: {{ params.rt03_lo }}/32 を EIGRP(D) で学習 (via RT03 {{ params.seg13 }}.2)"
    node: RT01
    command: "show ip route eigrp"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt03_lo }}/32"
      source_protocol: "eigrp"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg13 }}.2"
    points: {{ 20 if bfd else 25 }}

  - name: "RT02: {{ params.rt01_lo }}/32 を EIGRP(D) で学習（双方向性確認, via {{ params.seg12 }}.1）"
    node: RT02
    command: "show ip route eigrp"
    parser: "show ip route"
    find: "vrf.*.address_family.*.routes.*"
    match:
      route: "{{ params.rt01_lo }}/32"
      source_protocol: "eigrp"
      next_hop.next_hop_list.*.next_hop: "{{ params.seg12 }}.1"
    points: {{ 16 if bfd else 20 }}
{% if bfd %}

  - name: "RT01: BFD セッション ({{ params.seg12 }}.2) Up・EIGRP連動"
    node: RT01
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg12 }}.2"]
    match:
      state: "Up"
      registered_protocols.*: "EIGRP"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT01: BFD セッション ({{ params.seg13 }}.2) Up・EIGRP連動"
    node: RT01
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg13 }}.2"]
    match:
      state: "Up"
      registered_protocols.*: "EIGRP"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT02: BFD セッション ({{ params.seg12 }}.1) Up・EIGRP連動"
    node: RT02
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg12 }}.1"]
    match:
      state: "Up"
      registered_protocols.*: "EIGRP"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5

  - name: "RT03: BFD セッション ({{ params.seg13 }}.1) Up・EIGRP連動"
    node: RT03
    command: "show bfd neighbors details"
    parser: "show bfd neighbors details"
    find: ["our_address", "*", "neighbor_address", "{{ params.seg13 }}.1"]
    match:
      state: "Up"
      registered_protocols.*: "EIGRP"
      multiplier: {{ params.bfd_multiplier | default(3) }}
    points: 5
{% endif %}
