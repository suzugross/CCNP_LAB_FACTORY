#!/bin/bash
# PC02 (拠点2 サーバ・iperf3 受け側) 初期化
set -e
export DEBIAN_FRONTEND=noninteractive
log() { echo "[$(date -Is)] $*"; }

log "測定ツール導入 (iperf3)"
for i in 1 2 3; do
  apt-get update -qq && apt-get install -y -qq iperf3 && break
  sleep 10
done

log "netplan 差替え: ens2=mgmt静的 / ens3=拠点2 LAN 静的 + 対向拠点への経路"
rm -f /etc/netplan/50-cloud-init.yaml
cat > /etc/netplan/60-ccnp.yaml <<EOF
network:
  version: 2
  ethernets:
    ens2:
      addresses: [{{ mgmt_ip }}/{{ mgmt_prefixlen }}]
      routes:
        - to: default
          via: {{ mgmt_gw }}
      nameservers:
        addresses: [8.8.8.8]
    ens3:
      addresses: [192.168.20.20/24]
      routes:
        - to: 192.168.0.0/16
          via: 192.168.20.1
EOF
chmod 600 /etc/netplan/60-ccnp.yaml
netplan apply

log "iperf3 サーバを systemd 常駐化 (再起動しても採点・測定を受けられる)"
cat > /etc/systemd/system/ccnp-iperf3.service <<'EOF'
[Unit]
Description=CCNP iperf3 server (grading/measurement target)
After=network-online.target

[Service]
ExecStart=/usr/bin/iperf3 -s
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now ccnp-iperf3
log "DONE"
