#!/bin/bash
# PC01 (拠点1 業務端末・測定元) 初期化
set -e
export DEBIAN_FRONTEND=noninteractive
log() { echo "[$(date -Is)] $*"; }

log "測定ツール導入 (iperf3) — この時点は mgmt 側 default 経路で internet 到達可"
for i in 1 2 3; do
  apt-get update -qq && apt-get install -y -qq iperf3 && break
  sleep 10
done

log "netplan 差替え: ens2=mgmt静的 / ens3=拠点1 LAN 静的 + 対向拠点への経路"
rm -f /etc/netplan/50-cloud-init.yaml
cat > /etc/netplan/60-ccnp.yaml <<EOF
network:
  version: 2
  ethernets:
    ens2:
      addresses: [{{ mgmt_ip }}/{{ mgmt_prefixlen }}]
      routes:
        - to: default
          via: {{ mgmt_gw }}
      nameservers:
        addresses: [8.8.8.8]
    ens3:
      addresses: [192.168.10.10/24]
      routes:
        - to: 192.168.0.0/16
          via: 192.168.10.1
EOF
chmod 600 /etc/netplan/60-ccnp.yaml
netplan apply
log "DONE"
