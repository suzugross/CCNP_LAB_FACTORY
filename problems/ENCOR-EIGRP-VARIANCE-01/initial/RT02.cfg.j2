! ENCOR-EIGRP-VARIANCE-01 初期 (RT02) — successor 経路の中継。
!   links[0]=RT01 / links[1]=RT04
interface Loopback0
 ip address 10.2.2.2 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (10.12.12.0/30) ===
 ip address 10.12.12.2 255.255.255.252
 delay 10
 no shutdown
!
interface {{ links[1] }}
 description === to RT04 (10.24.24.0/30) ===
 ip address 10.24.24.1 255.255.255.252
 delay 10
 no shutdown
!
router eigrp VAR
 address-family ipv4 unicast autonomous-system 100
  af-interface Loopback0
   passive-interface
  exit-af-interface
  eigrp router-id 10.2.2.2
  network 10.2.2.2 0.0.0.0
  network 10.12.12.0 0.0.0.3
  network 10.24.24.0 0.0.0.3
 exit-address-family
!
