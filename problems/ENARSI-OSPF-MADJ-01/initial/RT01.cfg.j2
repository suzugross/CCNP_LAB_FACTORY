! ENARSI-OSPF-MADJ-01 initial (RT01 = west ABR: area 0 / 1 / 100)
!   links[0]=to RT02 direct(area100) / links[1]=to RT03(area0) / links[2]=to RT05(area1)
!   NOTE: description は IOL の文字化け回避のため英語 (PoC 知見)
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
!
interface Loopback100
 description === NMS probe target (area 100 - DO NOT MOVE) ===
 ip address 172.31.100.1 255.255.255.255
!
interface {{ links[0] }}
 description === to RT02 direct link (area 100 / NMS segment) ===
 ip address 10.1.12.1 255.255.255.252
 no shutdown
!
interface {{ links[1] }}
 description === to RT03 (area 0 backbone) ===
 ip address 10.1.13.1 255.255.255.252
 ip ospf cost 100
 no shutdown
!
interface {{ links[2] }}
 description === to RT05 (area 1) ===
 ip address 10.1.15.1 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 1.1.1.1
 network 1.1.1.1 0.0.0.0 area 0
 network 172.31.100.1 0.0.0.0 area 100
 network 10.1.12.0 0.0.0.3 area 100
 network 10.1.13.0 0.0.0.3 area 0
 network 10.1.15.0 0.0.0.3 area 1
!
