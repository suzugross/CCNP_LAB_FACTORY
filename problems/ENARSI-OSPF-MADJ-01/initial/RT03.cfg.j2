! ENARSI-OSPF-MADJ-01 initial (RT03 = area 0 backbone transit)
!   links[0]=to RT01 / links[1]=to RT04
interface Loopback0
 ip address 3.3.3.3 255.255.255.255
!
interface {{ links[0] }}
 description === to RT01 (area 0 backbone) ===
 ip address 10.1.13.2 255.255.255.252
 ip ospf cost 100
 no shutdown
!
interface {{ links[1] }}
 description === to RT04 (area 0 backbone) ===
 ip address 10.1.34.1 255.255.255.252
 ip ospf cost 100
 no shutdown
!
router ospf 1
 router-id 3.3.3.3
 network 3.3.3.3 0.0.0.0 area 0
 network 10.1.13.0 0.0.0.3 area 0
 network 10.1.34.0 0.0.0.3 area 0
!
