! ============================================================
! baseline (switch)  -- config 断片 / Jinja2 テンプレート
! L2スイッチ。管理は MGMT VLAN({{ mgmt_vlan }}) の SVI に IP を載せる。
! ※末尾に 'end' を置かない（day0 で initial を後ろに連結するため）
! ============================================================
hostname {{ inventory_hostname }}
!
! ラボ指紋: grade が採点前に照合し「MGMT IP が別ラボに当たる」誤採点を防ぐ。
alias exec labid CCNP-LAB-{{ (problem | hash('md5'))[:8] }}
!
ip domain name {{ ccnp_domain | default('ccnp.local') }}
no ip domain lookup
!
! --- 認証（Ansible のログイン情報と一致させる）---
enable secret {{ ansible_become_pass }}
username {{ ansible_user }} privilege 15 secret {{ ansible_ssh_pass }}
!
spanning-tree mode rapid-pvst
!
! --- 管理 VLAN / SVI ---
vlan {{ mgmt_vlan }}
 name MGMT
!
interface {{ mgmt_if }}
 description === MGMT (Ansible) ===
 switchport
 switchport mode access
 switchport access vlan {{ mgmt_vlan }}
 no shutdown
!
interface Vlan{{ mgmt_vlan }}
 description === MGMT SVI ===
 ip address {{ mgmt_ip }} {{ mgmt_mask | default('255.255.255.192') }}
 no shutdown
!
ip ssh version 2
!
! SSH鍵は exec コマンドのため startup に書けない → EEM で起動後に自動生成
event manager applet GEN-SSH-KEY authorization bypass
 event timer countdown time 30
 action 1.0 cli command "enable"
 action 2.0 cli command "configure terminal"
 action 3.0 cli command "crypto key generate rsa modulus 2048"
 action 4.0 syslog msg "EEM GEN-SSH-KEY: RSA key generated"
!
line con 0
 exec-timeout 0 0
 logging synchronous
line vty 0 4
 exec-timeout 0 0
 login local
 transport input ssh telnet
!
