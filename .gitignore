# ローカル環境設定（CML接続情報・管理IPプールなど各自の環境依存値）
# 雛形は group_vars/all/local.yml.example（コミット対象）。
group_vars/all/local.yml

# 設計メモ（非公開・ローカル保持）
DESIGN.md

# Python 仮想環境（巨大・再作成可能）
.venv/

# Python キャッシュ
__pycache__/
*.pyc
*.pyo

# Ansible が build_topology で再生成する成果物（再生成可能）
topologies/_generated/

# MGMT IP リース台帳（ランタイム状態。消えても mgmt_alloc.py gc で CML から復元可）
topologies/_state/

# 採点時の一時ファイル
grade_input.json
*.retry

# エディタ/OS の一時物
*.swp
*~
.DS_Store

# ラボ運用: ラボ作業フォルダ(provisionで生成/teardownで削除・使い捨て)
/lab/
