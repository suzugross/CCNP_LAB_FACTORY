---
# ============================================================================
# ローカル環境設定の雛形（テンプレート）
#
#   このファイルをコピーして自分の環境値に書き換える:
#       cp group_vars/all/local.yml.example group_vars/all/local.yml
#
#   local.yml は .gitignore 済み（コミットされない）。ここには「あなたのCML /
#   管理ネットワーク固有の値」だけを置く。Ansible は group_vars/all/ 配下の
#   *.yml を自動読込するため、local.yml を置けば全 playbook / スクリプトが参照する。
#   （この *.example ファイル自体は拡張子の都合で Ansible には読み込まれない）
# ============================================================================

# --- CML サーバ (cisco.cml コレクション / virl2_client 用) ---
cml_host: "192.0.2.10"          # あなたの CML コントローラの IP / ホスト名
cml_username: "admin"           # CML ログインユーザ
cml_password: "CHANGE_ME"       # CML ログインパスワード（★他サービスと使い回さない値に）
cml_verify_cert: false          # 自己署名証明書なら false

# --- MGMT（管理）ネットワーク ---
# CML の外部接続ブリッジ側にある、あなたの管理セグメントに合わせる。
# （CML 既定の "External Connection" を使う場合は自分の LAN セグメントに合わせる）
mgmt_mask: 255.255.255.192      # 管理セグメントのサブネットマスク
mgmt_prefixlen: 26              # 同じくプレフィックス長（Linux netplan 表記用）
mgmt_gw: 192.0.2.62             # 管理セグメントのデフォルトGW（Linuxノードの外部到達用）
mgmt_dns: [8.8.8.8, 8.8.4.4]    # Linuxノードが使う DNS

# === MGMT アドレスプール ========================================
# 全CMLノードのMGMTに first-fit で貸与する IP の一覧（topologies/mgmt_alloc.py が管理）。
# 使いたい台数ぶんの空きアドレスを列挙する。GW/予約と重複させないこと。
mgmt_pool:
  - 192.0.2.11
  - 192.0.2.12
  - 192.0.2.13
  - 192.0.2.14
  - 192.0.2.15
  # … 必要な台数ぶん追記する
